# Скопируйте в .env и заполните значения. Не коммитьте .env.
# Дублирует назначение .env_template (HTML-комментарии там для удобства в редакторе).

SECRET_KEY=change-me-generate-with-django-secret-key-generator
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# Только доверенные origin для CORS (без '*'). Для одного домена с тем же origin можно оставить пустым.
CORS_ALLOWED_ORIGINS=https://asco.kg,https://www.asco.kg
CORS_ALLOW_CREDENTIALS=true

# Preview (Vercel/Railway): отдельная БД; совпадение с PRODUCTION_DATABASE_NAME → ошибка старта
# PREVIEW_DEPLOYMENT=false
# VERCEL_ENV=
# RAILWAY_ENVIRONMENT=
PRODUCTION_DATABASE_NAME=ascodb
BLOCK_PREVIEW_PRODUCTION_DB=true
ALLOW_PREVIEW_USE_PRODUCTION_DB=false

# Сеть БД: deploy-check предупредит про «глобальный» IP; осознанно: DATABASE_ALLOW_PUBLIC_HOST=true
# DATABASE_ALLOW_PUBLIC_HOST=false

# HTTPS/HSTS в production: DEBUG=false, SECURE_SSL_REDIRECT=true (по умолчанию)
# SECURE_SSL_REDIRECT=true

# CSP (после теста в браузере; пусто = заголовок не отправляется)
# SECURE_CONTENT_SECURITY_POLICY=
# SECURE_CONTENT_SECURITY_POLICY_REPORT_ONLY=false

# Логи: JSON в stdout → asco.security; обычные логи в консоль и logs/django.log
LOG_TO_FILE=true
SECURITY_DENIED_PER_IP_THRESHOLD=30
SECURITY_REQUESTS_PER_MINUTE_ANOMALY=500

USE_SQLITE=false
DB_NAME=ascodb
DB_USER=ascouser
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432

REDIS_URL=
SESSION_COOKIE_AGE=1209600
REGISTRATION_ENABLED=false
TIME_ZONE=Asia/Bishkek

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET_ID=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_PRIVATE_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_PRIVATE_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

MAILGUN_API_KEY=
MAILGUN_SENDER_DOMAIN=
FROM_EMAIL=
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=
SERVER_EMAIL=

DJANGO_RECAPTCHA_PUBLIC_KEY=
DJANGO_RECAPTCHA_PRIVATE_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Секрет для setWebhook (заголовок X-Telegram-Bot-Api-Secret-Token)
TELEGRAM_WEBHOOK_SECRET=

# Вебхуки платежей
STRIPE_WEBHOOK_SECRET=
# ЮKassa: shopId и секретный ключ API (проверка уведомления через GET /v3/payments/{id})
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=

# Лимиты API (django-ratelimit + кэш; для production с несколькими воркерами задайте REDIS_URL)
API_RATE_LIMIT=100/m
API_MAX_REQUEST_BODY_BYTES=1048576
AI_GENERATION_LIMIT_FREE_PER_DAY=5
AI_GENERATION_LIMIT_PRO_PER_DAY=50

DJANGO_LOG_LEVEL=INFO
